# =============================================================================
# bookstack-rag-chatbot — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets and environment
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.secrets
*.pem
*.key
secrets/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv/
*.egg-info/
dist/
build/
pip-log.txt
pip-delete-this-directory.txt
.tox/

# -----------------------------------------------------------------------------
# Test, coverage, type-checker caches
# -----------------------------------------------------------------------------
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.pytest_cache/
.mypy_cache/
.ruff_cache/

# -----------------------------------------------------------------------------
# IDE / editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-compose.override.yml
docker-compose.override.yaml
*.dockerignore.local

# -----------------------------------------------------------------------------
# Runtime data (volumes, caches, sessions)
# -----------------------------------------------------------------------------
data/
chatbot_data/
bookstack_data/
mariadb_data/
flask_session/
sessions/
uploads/
upload/
media/

# -----------------------------------------------------------------------------
# Databases
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.sqlite-journal
*.db-journal

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
log/

# -----------------------------------------------------------------------------
# Backups
# -----------------------------------------------------------------------------
*.bak
*.backup
*.backup-*
backup/
backups/

# -----------------------------------------------------------------------------
# Generated exports / analytics
# -----------------------------------------------------------------------------
widget_analytics_*.csv
widget_analytics_*.json
*_widget_export.*
samples/loaded/
samples/__pycache__/

# -----------------------------------------------------------------------------
# Personal content (not for the public repo)
# -----------------------------------------------------------------------------
LINKEDIN_POST.md
REDDIT_POST.md
DRAFTS/
*.draft.md

# -----------------------------------------------------------------------------
# Nextcloud / rclone symlinks (developer workstation artefact)
# -----------------------------------------------------------------------------
*.rclonelink
