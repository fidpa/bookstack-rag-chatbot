# =============================================================================
# bookstack-rag-chatbot — environment template
# =============================================================================
# Copy this file to `.env` and fill in the real values. Never commit `.env`.
# Generate strong random secrets with:  openssl rand -hex 32
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
# Flask session signing key. REQUIRED. Use 64 hex chars from `openssl rand -hex 32`.
SECRET_KEY=replace-me-with-64-hex-chars

# Timezone applied to log timestamps and to all containers.
TZ=Europe/Berlin

# Flask runtime mode: production (default) or development.
FLASK_ENV=production
FLASK_DEBUG=false
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# LLM providers — configure AT LEAST ONE
# -----------------------------------------------------------------------------
# Azure OpenAI (recommended for production deployments).
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini

# Ollama (local fallback, e.g. `ollama run llama3.1`).
# Disabled by default — set ENABLE_OLLAMA_FALLBACK=true to allow it.
OLLAMA_BASE_URL=http://host.docker.internal:11434
ENABLE_OLLAMA_FALLBACK=false

# -----------------------------------------------------------------------------
# BookStack integration
# -----------------------------------------------------------------------------
# External URL the BookStack instance is reachable on (used in widget links).
BOOKSTACK_EXTERNAL_URL=http://localhost:6875

# BookStack port published on the Docker host.
BOOKSTACK_PORT=6875

# BookStack APP_KEY. Generate ONCE per deployment:
#   docker run --rm lscr.io/linuxserver/bookstack:25.07 \
#     php /app/www/artisan key:generate --show
# Then paste the full `base64:...` string below.
BOOKSTACK_APP_KEY=

# BookStack API token, created in BookStack: My Account → API Tokens → Create Token.
# The chatbot uses this to fetch wiki content for RAG indexing.
BOOKSTACK_TOKEN_ID=
BOOKSTACK_TOKEN_SECRET=

# Webhook shared secret. Leave EMPTY for stock BookStack — v25.07 does not sign
# webhook payloads and the chatbot relies on ALLOWED_VPN_IPS for authenticity.
# Set this only against a BookStack build that signs payloads (custom plugin or
# future release); the chatbot will then enforce HMAC-SHA256 verification.
BOOKSTACK_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Database (MariaDB for BookStack)
# -----------------------------------------------------------------------------
# CHANGE THESE before first start.
BOOKSTACK_DB_PASSWORD=change-me-strong-password
MYSQL_ROOT_PASSWORD=change-me-strong-password

# -----------------------------------------------------------------------------
# Chatbot backend
# -----------------------------------------------------------------------------
CHATBOT_PORT=8888

# -----------------------------------------------------------------------------
# Access control
# -----------------------------------------------------------------------------
# Comma-separated list of source IPs allowed to reach the chatbot widget.
# Use the network range of your LAN/VPN. Example: 10.0.0.0/8,192.168.0.0/16
# Leave empty to allow ANY source (NOT recommended outside dev).
ALLOWED_VPN_IPS=

# Enforce the allow-list. Set to false to bypass for local development only.
IP_ACCESS_CONTROL=true

# Sliding-window rate limit, applied per source IP.
RATE_LIMIT_PER_MINUTE=30

# -----------------------------------------------------------------------------
# Chatbot behaviour
# -----------------------------------------------------------------------------
# Override the default system prompt. Leave empty to use the built-in prompt.
# The default prompt responds in the user's language and cites sources briefly.
CHATBOT_SYSTEM_PROMPT=
